def cfg

pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        stage('Approve Build') {
            steps {
                input message: 'Proceed with build & deploy?', ok: 'Yes'
            }
        }

        stage('Load Config') {
            steps {
                script {
                    def cfgLoader = load "jenkins/functions/config.groovy"
                    cfg = cfgLoader()
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    def buildFn = load "jenkins/functions/build.groovy"
                    buildFn(cfg)
                }
            }
        }

        stage('Login & Push Image') {
            steps {
                script {
                    def dockerFn = load "jenkins/functions/docker.groovy"
                    dockerFn(cfg)
                }
            }
        }

        stage('Deploy to k3s') {
            steps {
                script {
                    def deployFn = load "jenkins/functions/deploy.groovy"
                    deployFn(cfg)
                }
            }
        }
    }

    post {
        always {
            script {
                sh "rm -rf ${cfg?.BUILD_DIR} || true"
            }
        }

        success {
            emailext(
                subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2 style="color:green;">Deployment SUCCESS</h2>
                    <p><b>Image:</b> ${cfg?.FULL_IMAGE}</p>
                    <p><b>Build:</b> ${env.BUILD_URL}</p>
                """,
                mimeType: 'text/html',
                to: 'aditya.rudola@quokkalabs.com'
            )
        }

        failure {
            emailext(
                subject: "FAILURE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2 style="color:red;">Deployment FAILED</h2>
                    <p><b>Check Logs:</b> ${env.BUILD_URL}</p>
                """,
                mimeType: 'text/html',
                to: 'aditya.rudola@quokkalabs.com'
            )
        }
    }
}